COMPOSE_PROJECT_NAME=project

PROJECT_HOSTNAME=project.example.com
PROJECT_ROOT=/var/www/html
PROJECT_MODE=dev

NGINX_VERSION=1.18-php-fpm-alpine3.11
NGINX_PORT=8083
NGINX_PORT_SSL=447

PHP_VERSION=7.4-fpm-alpine3.11
PHP_USER=user
## SMTP hostname example: localhost | 192.168.99.100 | smtp.gmail.com
SMTP_HOSTNAME=192.168.99.100
SMTP_PORT=1026
SMTP_FROM=team@example.com
## SMTP user example: user | user@example.com
SMTP_USER=
SMTP_PASSWORD=password

SSH_VERSION=php7.4-cli-alpine3.11
SSH_HOME=/var/www
SSH_USER=user
SSH_PASSWORD=password
SSH_PORT=2222

MARIADB_VERSION=10.4
MARIADB_PORT=3308
MARIADB_DATABASE=mariadb
MARIADB_USER=mariadb
MARIADB_PASSWORD=mariadb
MARIADB_ROOT_PASSWORD=root

POSTGRES_VERSION=12.2-alpine
POSTGRES_PORT=5434
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=postgres

MAILCATCHER_VERSION=alpine3.11
MAILCATCHER_SMTP_PORT=1026
MAILCATCHER_HOSTNAME=mailcatcher.example.com
MAILCATCHER_PORT=1081

ADMINER_VERSION=4.7-standalone
ADMINER_PORT=8084
ADMINER_PATH=/adminer
